{
  "name": "ankiniki",
  "version": "0.1.0",
  "description": "Anki companion tool for engineers",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "prepare": "husky install",
    "clean": "rm -rf node_modules packages/*/node_modules apps/*/node_modules packages/*/dist apps/*/dist",
    "precommit": "lint-staged",
    "setup": "./scripts/setup.sh",
    "check": "./scripts/quality-check.sh",
    "ci": "npm run check && npm run test",
    "serena:validate": "node scripts/validate-serena.js",
    "serena:setup": "./scripts/setup-serena.sh",
    "serena:test": "node scripts/test-serena.js",
    "ml-service:dev": "cd services/ml-service && uvicorn main:app --reload --port 8000",
    "ml-service:install": "cd services/ml-service && pip install -r requirements.txt",
    "ml-service:docker": "cd services/ml-service && docker build -t ankiniki-ml-service .",
    "ml-service:docker-run": "docker run -p 8000:8000 ankiniki-ml-service"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "husky": "^8.0.3",
    "lint-staged": "^13.2.3",
    "prettier": "^3.0.0",
    "tsx": "^3.12.7",
    "typescript": "^5.1.6"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/iray-tno/ankiniki.git"
  },
  "license": "MIT"
}
